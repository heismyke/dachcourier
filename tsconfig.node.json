{
  "include": ["vite.config.*", "vitest.config.*", "playwright.config.ts", "eslint.config.js"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
